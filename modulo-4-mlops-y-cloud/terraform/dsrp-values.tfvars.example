# Copy this file to dsrp-values.tfvars and fill in the real values.
# dsrp-values.tfvars is gitignored.

subscription_id = "00000000-0000-0000-0000-000000000000"
location        = "centralus"
prefix          = "dsrpm4"

# VM. Standard_D2as_v4 (2 vCPU / 8 GiB / AMD EPYC GP) es el default.
# Por qué NO B2s: la familia BS no la ofrece la suscripción del curso en
# eastus/eastus2/westus2. DASv4 sí está disponible en centralus/westus3.
# Verifica antes de cambiar: `task vm:check-skus`
vm_size = "Standard_D2as_v4"

# Terraform creates the storage account itself. This is just the blob container
# name inside it (same one used by the notebooks and the Docker image).
azure_storage_container = "dsrp-modulo4"

# Replace CHANGE_ME with your GitHub username — the image is built by
# .github/workflows/build-modulo4-image.yml.
image_ref = "ghcr.io/CHANGE_ME/dsrp-modulo4-trainer:latest"

# If your GHCR image is public, leave these empty.
# If private, create a PAT with read:packages and fill them in.
ghcr_username = ""
ghcr_token    = ""

# CIDR autorizado para SSH (puerto 22). Tres opciones:
#   "auto"             Terraform consulta tu IP pública y la usa como /32   ← DEFAULT
#   "203.0.113.42/32"  IP explícita (útil en CI o si te cambia el IP)
#   "0.0.0.0/0"        abierto al mundo — SOLO si sabes lo que haces
ssh_allowed_cidr = "auto"

# OPTIONAL — cron-like schedule for the trainer. Leave empty to keep the
# original behavior (one shot at first boot). Examples:
#   "hourly"               every hour
#   "daily"                every day at 00:00 UTC
#   "*-*-* 03:00:00"       every day at 03:00 UTC
#   "Mon..Fri 08:00:00"    weekdays at 08:00 UTC
trainer_schedule = ""
